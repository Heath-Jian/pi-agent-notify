{
  "name": "pi-agent-notify",
  "version": "0.6.3",
  "description": "Pi extension that sends host terminal or desktop notifications when an agent run finishes or fails.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "notification",
    "notify",
    "agent",
    "desktop-notifications",
    "terminal",
    "zap",
    "macos",
    "windows",
    "linux"
  ],
  "homepage": "https://github.com/Heath-Jian/pi-agent-notify#readme",
  "bugs": {
    "url": "https://github.com/Heath-Jian/pi-agent-notify/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Heath-Jian/pi-agent-notify.git"
  },
  "license": "MIT",
  "author": "Heath He",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "scripts": {
    "pack:check": "npm pack --dry-run",
    "publish:public": "npm publish --access public"
  },
  "files": [
    "extensions",
    "scripts/pi-agent-notify-helper.swift",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
